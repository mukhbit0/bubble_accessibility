<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Accessibility service mode -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service mode -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application>

        <!-- Accessibility service (mode = accessibilityService / auto) -->
        <service
            android:name="com.ionicerrrrscode.bubble_accessibility.BubbleAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/bubble_accessibility_config" />
        </service>

        <!-- Foreground service (mode = foregroundService / auto) -->
        <service
            android:name="com.ionicerrrrscode.bubble_accessibility.BubbleForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

    </application>

</manifest>
